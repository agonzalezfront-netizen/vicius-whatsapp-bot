ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-haiku-4-5
TZ=America/Santiago
AUTH_DIR=./auth_info_baileys
MENU_PATH=./config/menu.json
LOG_LEVEL=info
JITTER_MIN_MS=800
JITTER_MAX_MS=3000
HISTORY_MAX_TURNS=12

# ── WhatsApp Cloud API (Meta directa, sin BSP) — Fase A ──
# TRANSPORT elige la capa de transporte: 'baileys' (default, actual) o 'cloud'.
TRANSPORT=baileys
GRAPH_API_VERSION=v21.0
# Tenant único del piloto (Sazón). Multi-tenant: usar WA_TENANTS (JSON) en su lugar.
WA_PHONE_NUMBER_ID=        # id del número de WhatsApp (de la app de Meta)
WA_TOKEN=                  # access token (temp 24h al inicio → System User permanente)
WA_BUSINESS_NAME=sazon
WA_VERIFY_TOKEN=           # token que defino yo para el handshake del webhook
WA_APP_SECRET=            # App Secret de la app Meta (verifica la firma del webhook)
# Multi-negocio (opcional): WA_TENANTS=[{"phoneNumberId":"...","token":"...","name":"..."}]
